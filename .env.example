# Copy to .env and fill in values:
#   cp .env.example .env

# PostgreSQL connection string (e.g. Neon, Vercel Postgres, Supabase).
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Public site URL (metadata, sitemap, robots)
SITE_URL="http://localhost:3000"

# Admin dashboard path segment (e.g. /admin/login)
ADMIN_PATH="admin"

# Random secret for signing admin session JWTs (32+ characters)
AUTH_SECRET="change-me-to-a-long-random-string"

# Bcrypt hash of the admin password. Generate with:
#   npx tsx scripts/hash-password.ts your-password
# Use double quotes and escaped $ (Next.js expands $ in .env values).
ADMIN_PASSWORD_HASH=""

# Vercel Blob read/write token, used for admin image uploads.
# On Vercel: create a Blob store and it's injected automatically; pull it
# locally with `vercel env pull`. Or copy it from the store's settings.
BLOB_READ_WRITE_TOKEN=""
