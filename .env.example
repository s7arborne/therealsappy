# Copy to .env and fill in values:
#   cp .env.example .env

# SQLite (default). For Postgres, change prisma/schema provider and use a postgres URL.
DATABASE_URL="file:./dev.db"

# Public site URL (metadata, sitemap, robots)
SITE_URL="http://localhost:3000"

# Admin dashboard path segment (e.g. /admin/login)
ADMIN_PATH="admin"

# Random secret for signing admin session JWTs (32+ characters)
AUTH_SECRET="change-me-to-a-long-random-string"

# Bcrypt hash of the admin password. Generate with:
#   npx tsx scripts/hash-password.ts your-password
# Use double quotes and escaped $ (Next.js expands $ in .env values).
ADMIN_PASSWORD_HASH=""
